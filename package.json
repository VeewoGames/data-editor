{
  "name": "data-editor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "node dev.mjs",
    "open": "node open.mjs",
    "stop": "node stop.mjs",
    "service:status": "node scripts/service-finalize.mjs --status",
    "service:finalize": "node scripts/service-finalize.mjs --cleanup --recover",
    "build": "vite build",
    "start": "node server.mjs --project . --port 8787 --static dist",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs && tsc --noEmit",
    "test:e2e": "playwright test",
    "profile:prototypes-expansion": "node tests/perf/prototypes-expansion-profile.mjs",
    "profile:prototypes-expansion:static": "node tests/perf/prototypes-expansion-static.mjs",
    "profile:prototypes-expansion:wrap-observe": "node tests/perf/prototypes-expansion-wrap-observe.mjs",
    "streamline:repair-collisions": "node scripts/streamline-export/repair-streamline-manifest-collisions.mjs artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json",
    "streamline:generate-registry": "node scripts/streamline-export/generate-shared-view-streamline-icons.mjs artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json",
    "streamline:audit-collisions": "node scripts/streamline-export/audit-streamline-collisions.mjs --output artifacts/streamline-export/shared-view-collision-report.json artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json",
    "streamline:sync-registry": "npm run streamline:generate-registry && npm run streamline:audit-collisions"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21",
    "typescript": "^5.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  }
}
