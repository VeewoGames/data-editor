{
  "name": "data-editor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "node dev.mjs",
    "open": "node open.mjs",
    "stop": "node stop.mjs",
    "service:status": "node scripts/service-finalize.mjs --status",
    "service:finalize": "node scripts/service-finalize.mjs --cleanup --recover",
    "build": "vite build",
    "start": "node server.mjs --project . --port 8787 --static dist",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs && tsc --noEmit",
    "test:e2e": "playwright test",
    "profile:prototypes-expansion": "node tests/perf/prototypes-expansion-profile.mjs",
    "profile:prototypes-expansion:static": "node tests/perf/prototypes-expansion-static.mjs",
    "profile:prototypes-expansion:wrap-observe": "node tests/perf/prototypes-expansion-wrap-observe.mjs",
    "profile:shared-view-icons": "node tests/perf/shared-view-icons-profile.mjs",
    "shared-view-icons:inventory-legacy": "node scripts/shared-view-icons/export-legacy-inventory.mjs",
    "streamline:repair-collisions": "node scripts/streamline-export/repair-streamline-manifest-collisions.mjs artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json",
    "streamline:repair-collisions:dry-run": "node scripts/streamline-export/repair-streamline-manifest-collisions.mjs --dry-run artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json",
    "streamline:repair-collisions:core-solid": "node scripts/streamline-export/repair-streamline-manifest-collisions.mjs artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:repair-collisions:core-solid:dry-run": "node scripts/streamline-export/repair-streamline-manifest-collisions.mjs --dry-run artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:generate-registry": "node scripts/streamline-export/generate-shared-view-streamline-icons.mjs artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:generate-registry:core-solid-preview": "node scripts/streamline-export/generate-shared-view-streamline-icons.mjs --runtime-output artifacts/streamline-export/core-solid-preview-registry.mjs --types-output artifacts/streamline-export/core-solid-preview-registry.d.ts artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:audit-collisions": "node scripts/streamline-export/audit-streamline-collisions.mjs --output artifacts/streamline-export/shared-view-collision-report.json artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-line-full.manifest.json artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:audit-collisions:core-solid": "node scripts/streamline-export/audit-streamline-collisions.mjs --output artifacts/streamline-export/core-solid-collision-report.json artifacts/streamline-export/core-solid-full.manifest.json",
    "streamline:capture-detail-sources": "node scripts/streamline-export/capture-streamline-detail-sources.mjs",
    "streamline:hydrate-hashes": "node scripts/streamline-export/hydrate-streamline-manifest-hashes.mjs",
    "streamline:import-item-hashes": "node scripts/streamline-export/import-streamline-item-hashes.mjs",
    "streamline:import-official-metadata": "node scripts/streamline-export/import-streamline-official-metadata.mjs",
    "streamline:import-detail-sources": "node scripts/streamline-export/import-streamline-detail-source-metadata.mjs",
    "streamline:import-mcp-svg": "node scripts/streamline-export/import-streamline-svg-from-mcp.mjs",
    "streamline:import-mcp-svg:session": "node scripts/streamline-export/run-streamline-mcp-svg-session.mjs",
    "streamline:extract-browser-auth": "node scripts/streamline-export/extract-streamline-browser-auth.mjs",
    "streamline:probe-browser-auth": "node scripts/streamline-export/probe-streamline-browser-auth.mjs",
    "streamline:official-tags-pipeline": "node scripts/streamline-export/run-streamline-official-tags-pipeline.mjs",
    "streamline:build-tag-knowledge:micro-solid": "node scripts/streamline-export/build-streamline-tag-knowledge.mjs artifacts/streamline-export/micro-solid-full.manifest.json",
    "streamline:suggest-tags:micro-solid": "node scripts/streamline-export/suggest-streamline-tags.mjs artifacts/streamline-export/micro-solid-full.manifest.json",
    "streamline:apply-auto-accept:micro-solid": "node scripts/streamline-export/apply-streamline-tag-suggestions.mjs artifacts/streamline-export/micro-solid-full.manifest.json artifacts/streamline-export/micro-solid-tag-suggestions.json",
    "streamline:promote-review-required:micro-solid": "node scripts/streamline-export/promote-streamline-review-required.mjs artifacts/streamline-export/micro-solid-tag-suggestions.json",
    "streamline:metadata-session:mcp": "node scripts/streamline-export/run-streamline-metadata-session.mjs --transport mcp",
    "streamline:reset-manifest-items": "node scripts/streamline-export/reset-streamline-manifest-items.mjs",
    "streamline:sync-mcp-metadata": "node scripts/streamline-export/sync-streamline-metadata-from-mcp.mjs",
    "streamline:sync-registry": "npm run streamline:generate-registry && npm run streamline:audit-collisions",
    "streamline:verify-svg": "node scripts/streamline-export/verify-streamline-svg.mjs",
    "streamline:verify-svg:core-solid": "node scripts/streamline-export/verify-streamline-svg.mjs artifacts/streamline-export/core-solid-full.manifest.json",
    "tabler:import-snapshot": "node scripts/tabler-export/import-tabler-tagged-snapshot.mjs",
    "tabler:generate-registry": "node scripts/tabler-export/generate-shared-view-tabler-icons.mjs",
    "test:streamline-export": "node --test tests/streamline-export/*.test.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21",
    "typescript": "^5.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  }
}
